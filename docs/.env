# ============================================================
# Traveloop — Environment Variables
# Copy this file to .env.local and fill in actual values
# DO NOT commit .env.local to version control
# ============================================================

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_NAME=Traveloop
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
# Production: https://traveloop.vercel.app

# ============================================================
# SUPABASE
# ============================================================
# Get from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example_service_role_key

# ============================================================
# DATABASE (Prisma)
# ============================================================
# Primary: Supabase PostgreSQL connection string
# Get from: Supabase Dashboard → Settings → Database → Connection String
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.your-project-id.supabase.co:5432/postgres

# Failover: Local PostgreSQL
DATABASE_URL_LOCAL=postgresql://postgres:password@localhost:5432/traveloop_local

# ============================================================
# AI PROVIDERS
# ============================================================
# Google Gemini API (Primary AI)
# Get from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSy_your_gemini_api_key

# Groq API (Fallback AI)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key

# AI Configuration
AI_RATE_LIMIT_PER_DAY=10
AI_MAX_TIMEOUT_MS=30000
AI_PRIMARY_PROVIDER=gemini
AI_FALLBACK_PROVIDER=groq

# ============================================================
# EMAIL (Resend)
# ============================================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@traveloop.app

# ============================================================
# ANALYTICS (PostHog)
# ============================================================
# Get from: https://app.posthog.com → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================================
# ERROR MONITORING (Sentry)
# ============================================================
# Get from: https://sentry.io → Project Settings → Client Keys
NEXT_PUBLIC_SENTRY_DSN=https://your_key@sentry.io/your_project_id
SENTRY_AUTH_TOKEN=sntrys_your_sentry_auth_token
SENTRY_ORG=your-org
SENTRY_PROJECT=traveloop

# ============================================================
# MAPS
# ============================================================
# Leaflet + OpenStreetMap: No API key required (free)
# Optional: Mapbox token for premium map tiles
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token

# ============================================================
# SECURITY
# ============================================================
# Session encryption secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your_random_session_secret_32_chars

# Rate limiting
API_RATE_LIMIT_PER_MINUTE=100
AUTH_RATE_LIMIT_PER_MINUTE=10
