# ==============================================================================
# Traveloop — Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# NEVER commit .env.local to version control.
# All secrets must be set in Vercel Dashboard for production.
# ==============================================================================

# ==============================================================================
# SUPABASE (Required)
# Get these from: https://supabase.com/dashboard → Project Settings → API
# ==============================================================================

# Public Supabase URL — safe to expose in browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public Supabase anon key — safe to expose (RLS enforces security)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# Service role key — NEVER expose to client, server-side only
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key

# ==============================================================================
# DATABASE (Required)
# Get connection string from: Supabase Dashboard → Settings → Database
# ==============================================================================

# Prisma connection URL (pooled connection via Supabase PgBouncer)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection URL (for Prisma migrations — bypasses PgBouncer)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ==============================================================================
# AI SERVICES (Required for AI features)
# ==============================================================================

# Google Gemini API — Primary AI provider
# Get from: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Groq API — Fallback AI provider
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# ==============================================================================
# MONITORING (Optional but recommended)
# ==============================================================================

# Sentry DSN — Error monitoring
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o0.ingest.us.sentry.io/0

# Sentry Auth Token — for source map uploads
SENTRY_AUTH_TOKEN=sntrys_your-auth-token

# PostHog — Analytics and feature flags
# Get from: https://us.posthog.com → Project Settings
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ==============================================================================
# EMAIL (Required for auth emails)
# ==============================================================================

# Resend API Key — Transactional emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# From email address (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ==============================================================================
# APP CONFIG
# ==============================================================================

# Application URL (used for email links, OAuth callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App version (used for Sentry release tracking)
NEXT_PUBLIC_APP_VERSION=0.1.0

# Node environment (auto-set by Next.js, don't change manually)
# NODE_ENV=development
